# Your Gmail address
EMAIL_SENDER=you@gmail.com

# Gmail App Password (NOT your login password)
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Where to send alerts (can be same as sender)
EMAIL_RECEIVER=you@gmail.com

# Alert when volume is this many times above 20-day average (default: 3.0)
VOLUME_THRESHOLD=3.0

# How often to scan in seconds (default: 1800 = 30 minutes)
CHECK_INTERVAL=1800
